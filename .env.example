# Copy to .env (which is gitignored). Never commit secrets.
# You only need the keys for substrates you actually use.
# Real-LLM substrates auto-load this file via python-dotenv.

# Anthropic (default real-LLM substrate)
ANTHROPIC_API_KEY=

# OpenAI — also covers any OpenAI-compatible endpoint via OPENAI_BASE_URL
# (Together / Fireworks / Groq / vLLM / LMStudio / llama.cpp server …)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.together.xyz/v1

# Google Gemini
GOOGLE_API_KEY=

# Mistral
MISTRAL_API_KEY=

# Nous Hermes Agent (stub in D1; promoted in D1 follow-up)
# NOUS_API_KEY=

# OpenClaw (stub; the real integration is --substrate=client-inherited in D2)
# OPENCLAW_API_KEY=
